#!/usr/bin/env python3
"""yaklog-sub: per-agent SSE broker daemon.

One daemon per agent-id. Holds a long-lived /stream connection to yaklog
and writes each received event as one NDJSON line to events.ndjson. Claude's
Monitor (or any tail -F consumer) reads from that file. The daemon's
identity is the agent-id, not the UID — multiple Claude sessions for the
same agent share one daemon and one event log.

State directory: $XDG_RUNTIME_DIR/yaklog/<agent-id>/  (or $HOME/.run/yaklog/<agent-id>/)
  lock           — exclusive flock; second daemon for same agent-id refuses to start
  cursor         — last seq durably appended to events.ndjson (atomic write)
  events.ndjson  — append-only, one server message per line
  daemon.log     — daemon's own stderr

Stdlib only. Python 3.8+.
"""

from __future__ import annotations

import argparse
import errno
import fcntl
import json
import os
import select
import signal
import sys
import threading
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Optional

VERSION = "0.5.1"

DEFAULT_RECONNECT_MIN_S = 1.0
DEFAULT_RECONNECT_MAX_S = 30.0
READ_TIMEOUT_S = 60.0
# Watchdog: server emits ': keepalive\n\n' every 15s. If no bytes reach the
# client for STREAM_RECV_TIMEOUT_S, treat the connection as silently dead
# (kernel-level RST not yet observed) and force reconnect. Without this,
# a stale ESTAB socket post-server-restart can hang readline() until OS
# TCP keepalive fires (Linux default ~2h11m). See yaklog #4245 / #4266.
STREAM_RECV_TIMEOUT_S = 30.0

# ADR-0016 Phase-1 (yaklog #4280) — daemon presence/liveness:
DEFAULT_HEARTBEAT_S = 30.0          # T_HB; daemon publishes presence every N seconds
DEFAULT_STALL_THRESHOLD_S = 120.0   # T2; no hook fire within this -> session_state=unknown
HOOK_TO_SESSION_STATE = {
    "SessionStart": "active",
    "PreToolUse": "tool_running",
    "PostToolUse": "idle_between_tools",
    "Stop": "idle",
    "SessionEnd": "idle",
}


class GracefulExit(Exception):
    pass


def state_dir(agent_id: str) -> Path:
    base = os.environ.get("XDG_RUNTIME_DIR")
    if not base:
        base = str(Path.home() / ".run")
    return Path(base) / "yaklog" / agent_id


def atomic_write_text(path: Path, text: str) -> None:
    tmp = path.with_suffix(path.suffix + ".tmp")
    with open(tmp, "w") as f:
        f.write(text)
        f.flush()
        os.fsync(f.fileno())
    os.replace(tmp, path)


def read_cursor(path: Path) -> int:
    try:
        return int(path.read_text().strip() or "0")
    except FileNotFoundError:
        return 0
    except ValueError:
        return 0


def acquire_lock(lock_path: Path):
    fd = os.open(str(lock_path), os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError as e:
        os.close(fd)
        if e.errno in (errno.EWOULDBLOCK, errno.EACCES):
            raise SystemExit(
                f"yaklog-sub: another daemon already holds {lock_path}; refusing to start"
            )
        raise
    os.write(fd, f"{os.getpid()}\n".encode())
    os.fsync(fd)
    return fd  # caller keeps fd alive; flock released on close/exit


class EventLog:
    """Append-only NDJSON sink with cursor advance after fsync."""

    def __init__(self, events_path: Path, cursor_path: Path):
        self.events_path = events_path
        self.cursor_path = cursor_path
        self._fh = open(self.events_path, "a", buffering=1)  # line-buffered

    def append(self, msg: dict) -> None:
        seq = msg.get("seq") or msg.get("id")
        if not isinstance(seq, int):
            raise ValueError(f"event missing integer id/seq: {msg!r}")
        line = json.dumps(msg, separators=(",", ":"), sort_keys=False) + "\n"
        self._fh.write(line)
        self._fh.flush()
        os.fsync(self._fh.fileno())
        atomic_write_text(self.cursor_path, str(seq))

    def close(self) -> None:
        try:
            self._fh.close()
        except Exception:
            pass


def build_stream_url(base: str, agent_id: str, aliases: list[str], since: int) -> str:
    mention_tokens = [agent_id] + list(aliases) + ["everyone"]
    seen: set[str] = set()
    deduped = []
    for t in mention_tokens:
        if t and t not in seen:
            seen.add(t)
            deduped.append(t)
    params = {
        "exclude_sender": agent_id,
        "mention": ",".join(deduped),
        "since": str(since),
    }
    return f"{base.rstrip('/')}/stream?{urllib.parse.urlencode(params)}"


def open_stream(url: str, token: str):
    req = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Bearer {token}",
            "Accept": "text/event-stream",
            "Cache-Control": "no-cache",
        },
    )
    return urllib.request.urlopen(req, timeout=READ_TIMEOUT_S)


def post_presence(presence_url: str, token: str, payload: dict, timeout: float = 10.0) -> Optional[int]:
    """POST to /presence/event. Returns HTTP status code or None on transport error.
    Best-effort: errors are logged but never raised — presence is non-load-bearing
    relative to the daemon's primary SSE-consume responsibility."""
    body = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        presence_url,
        data=body,
        method="POST",
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status
    except urllib.error.HTTPError as e:
        sys.stderr.write(f"yaklog-sub: presence post HTTP {e.code}: {e.reason}\n")
        sys.stderr.flush()
        return e.code
    except (urllib.error.URLError, OSError) as e:
        sys.stderr.write(f"yaklog-sub: presence post transport error: {e}\n")
        sys.stderr.flush()
        return None


class PresencePublisher:
    """L1 daemon TTL heartbeat (ADR-0016 §1) + L2 hook tail (ADR-0016 §1.L2).

    Runs in a background thread. Tails $XDG_RUNTIME_DIR/yaklog/<agent>/state.jsonl
    for hook events that update session_state. Publishes a presence heartbeat
    every T_HB seconds AND immediately on session_state change."""

    def __init__(self, presence_url: str, token: str, agent_id: str, state_jsonl_path: Path,
                 heartbeat_s: float, stall_threshold_s: float, stop_flag: dict, runtime_state: dict,
                 messages_url: Optional[str] = None, agents_backcompat: bool = True,
                 host: Optional[str] = None):
        self.presence_url = presence_url
        self.token = token
        self.agent_id = agent_id
        self.state_jsonl_path = state_jsonl_path
        self.heartbeat_s = heartbeat_s
        self.stall_threshold_s = stall_threshold_s
        self.stop_flag = stop_flag
        self.runtime_state = runtime_state  # shared dict: cursor_position, sse_connected
        self.session_state = "active"
        self.last_hook_at: Optional[str] = None
        self.last_hook_monotonic = time.monotonic()
        # ADR-0016 Phase-1.5 — Q5(a) #agents back-compat: daemon publishes
        # canonical online/offline events to #agents channel during the
        # Phase-1 transition window. Existing #3568 manual-post consumers
        # continue to work; new consumers query GET /presence directly.
        self.messages_url = messages_url
        self.agents_backcompat = agents_backcompat and (messages_url is not None)
        self.host = host or os.uname().nodename

    def _build_payload(self, daemon_state: str = "up", reason: Optional[str] = None) -> dict:
        # If no hook fire within stall threshold AND not freshly started, mark unknown.
        ss = self.session_state
        if (time.monotonic() - self.last_hook_monotonic) > self.stall_threshold_s:
            ss = "unknown"
        payload = {
            "agent_id": self.agent_id,
            "daemon_state": daemon_state,
            "session_state": ss,
            "cursor_position": self.runtime_state.get("cursor_position"),
            "lock_held": True,
            "sse_connected": self.runtime_state.get("sse_connected", False),
            "last_hook_at": self.last_hook_at,
        }
        if reason:
            payload["reason"] = reason
        return payload

    def _process_hook_line(self, raw: str) -> bool:
        """Parse one state.jsonl line. Returns True if session_state changed."""
        try:
            event = json.loads(raw)
        except json.JSONDecodeError:
            return False
        hook_event = event.get("event")
        new_state = HOOK_TO_SESSION_STATE.get(hook_event)
        if new_state is None:
            return False
        ts = event.get("ts")
        if isinstance(ts, str):
            self.last_hook_at = ts
        self.last_hook_monotonic = time.monotonic()
        if new_state != self.session_state:
            self.session_state = new_state
            return True
        return False

    def _post_agents_backcompat(self, event: str) -> None:
        """ADR-0016 P1.7: post canonical online/offline event to #agents
        channel for back-compat with #3568 manual-post consumers. State-
        change-driven (startup, shutdown), not per-heartbeat."""
        if not self.agents_backcompat:
            return
        body = json.dumps({
            "event": event,
            "host": self.host,
            "ts": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "via": f"yaklog-sub v{VERSION} P1.7-back-compat",
        })
        payload = {
            "channel": "agents",
            "sender": self.agent_id,
            "body": body,
            "metadata": {"type": "presence", "event": event},
        }
        post_presence(self.messages_url, self.token, payload)

    def run(self) -> None:
        """Main publisher loop. Tails state.jsonl + heartbeats."""
        # Open state.jsonl if present; tolerate it not existing yet
        fh = None
        try:
            self.state_jsonl_path.parent.mkdir(parents=True, exist_ok=True)
            fh = open(self.state_jsonl_path, "a+", encoding="utf-8")
            fh.seek(0, os.SEEK_END)  # tail from current end
        except OSError as e:
            sys.stderr.write(f"yaklog-sub: state.jsonl open failed: {e}; presence will publish heartbeat-only\n")
            sys.stderr.flush()

        # Initial heartbeat on startup + ADR-0016 P1.7 #agents back-compat
        post_presence(self.presence_url, self.token, self._build_payload(reason="daemon_start"))
        self._post_agents_backcompat("online")
        next_hb_at = time.monotonic() + self.heartbeat_s

        while not self.stop_flag["flag"]:
            now = time.monotonic()
            sleep_s = min(1.0, max(0.0, next_hb_at - now))
            time.sleep(sleep_s)
            if self.stop_flag["flag"]:
                break

            # Drain any new state.jsonl lines
            if fh is not None:
                changed = False
                while True:
                    line = fh.readline()
                    if not line:
                        break
                    if self._process_hook_line(line.rstrip("\r\n")):
                        changed = True
                if changed:
                    post_presence(self.presence_url, self.token, self._build_payload(reason="hook_state_change"))

            # Heartbeat tick
            if time.monotonic() >= next_hb_at:
                post_presence(self.presence_url, self.token, self._build_payload(reason="heartbeat"))
                next_hb_at = time.monotonic() + self.heartbeat_s

        if fh is not None:
            try: fh.close()
            except Exception: pass

        # Final beat — graceful daemon_state=down so swarm sees us go offline
        # immediately rather than waiting T_TTL. Also fires #agents
        # back-compat 'offline' event per ADR-0016 P1.7.
        post_presence(self.presence_url, self.token, self._build_payload(daemon_state="down", reason="daemon_shutdown"))
        self._post_agents_backcompat("offline")


def parse_sse(stream, on_event, should_stop):
    """Yield SSE events from a urlopen()'d response. on_event(msg_dict) is
    called for each `event: message` frame. Returns when stream ends, when
    should_stop() returns True, or when STREAM_RECV_TIMEOUT_S elapses with
    no bytes from the server (silent-TCP-death watchdog).
    """
    event_type: Optional[str] = None
    data_lines: list[str] = []
    last_id: Optional[str] = None

    try:
        fd = stream.fileno()
    except (OSError, ValueError, AttributeError):
        fd = None

    while True:
        if should_stop():
            return

        # Watchdog: only block in readline() if either (a) data is buffered
        # in user-space (peek non-empty) or (b) the kernel reports the fd
        # readable within STREAM_RECV_TIMEOUT_S. Otherwise, treat the
        # connection as silently dead and return to trigger reconnect.
        try:
            buffered = stream.peek(1)
        except (OSError, ValueError, AttributeError):
            buffered = b""

        if not buffered and fd is not None:
            try:
                ready, _, _ = select.select([fd], [], [], STREAM_RECV_TIMEOUT_S)
            except (OSError, ValueError):
                return  # fd closed or invalid; reconnect
            if not ready:
                sys.stderr.write(
                    f"yaklog-sub: no bytes from server for {STREAM_RECV_TIMEOUT_S:.0f}s "
                    f"(server keepalive interval is 15s); reconnecting\n"
                )
                sys.stderr.flush()
                return

        raw = stream.readline()
        if not raw:
            return  # server closed
        line = raw.decode("utf-8", errors="replace").rstrip("\r\n")
        if line == "":
            if data_lines and event_type == "message":
                payload = "\n".join(data_lines)
                try:
                    msg = json.loads(payload)
                except json.JSONDecodeError as e:
                    sys.stderr.write(f"sse parse error: {e}: {payload!r}\n")
                else:
                    on_event(msg)
            event_type = None
            data_lines = []
            continue
        if line.startswith(":"):
            continue  # comment / keepalive
        if ":" in line:
            field, _, value = line.partition(":")
            if value.startswith(" "):
                value = value[1:]
        else:
            field, value = line, ""
        if field == "event":
            event_type = value
        elif field == "data":
            data_lines.append(value)
        elif field == "id":
            last_id = value
        # other fields ignored


def run(args) -> int:
    aliases = [a.strip() for a in (args.aliases or "").split(",") if a.strip()]
    sd = state_dir(args.agent_id)
    sd.mkdir(parents=True, exist_ok=True)
    lock_path = sd / "lock"
    cursor_path = sd / "cursor"
    events_path = sd / "events.ndjson"
    state_jsonl_path = sd / "state.jsonl"

    lock_fd = acquire_lock(lock_path)  # held until process exit

    token = Path(args.token_file).read_text().strip()
    log = EventLog(events_path, cursor_path)

    stop = {"flag": False}

    def handle_signal(signum, _frame):
        stop["flag"] = True

    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    backoff = DEFAULT_RECONNECT_MIN_S
    sys.stderr.write(f"yaklog-sub v{VERSION}: agent={args.agent_id} state={sd}\n")
    sys.stderr.flush()

    # Shared runtime state for the presence publisher to read snapshots of.
    runtime_state = {"cursor_position": read_cursor(cursor_path), "sse_connected": False}

    presence_thread: Optional[threading.Thread] = None
    publisher: Optional[PresencePublisher] = None
    if not args.presence_disabled:
        url_base = (args.presence_url or args.url).rstrip("/")
        presence_url = url_base + "/presence/event"
        messages_url = url_base + "/messages" if not args.no_agents_backcompat else None
        publisher = PresencePublisher(
            presence_url=presence_url,
            token=token,
            agent_id=args.agent_id,
            state_jsonl_path=state_jsonl_path,
            heartbeat_s=args.heartbeat_s,
            stall_threshold_s=args.stall_threshold_s,
            stop_flag=stop,
            runtime_state=runtime_state,
            messages_url=messages_url,
            agents_backcompat=not args.no_agents_backcompat,
            host=args.host or os.uname().nodename,
        )
        presence_thread = threading.Thread(target=publisher.run, daemon=True, name="presence")
        presence_thread.start()
        backcompat_str = "+#agents back-compat" if publisher.agents_backcompat else ""
        sys.stderr.write(f"yaklog-sub: presence publisher started ({presence_url}; T_HB={args.heartbeat_s}s{(' ' + backcompat_str) if backcompat_str else ''})\n")
        sys.stderr.flush()

    try:
        while not stop["flag"]:
            since = read_cursor(cursor_path)
            url = build_stream_url(args.url, args.agent_id, aliases, since)
            try:
                resp = open_stream(url, token)
            except (urllib.error.URLError, urllib.error.HTTPError, OSError) as e:
                runtime_state["sse_connected"] = False
                sys.stderr.write(f"yaklog-sub: connect failed: {e}; sleeping {backoff:.1f}s\n")
                sys.stderr.flush()
                _sleep_interruptible(backoff, stop)
                backoff = min(backoff * 2, DEFAULT_RECONNECT_MAX_S)
                continue
            backoff = DEFAULT_RECONNECT_MIN_S
            runtime_state["sse_connected"] = True

            def on_event(msg):
                try:
                    log.append(msg)
                    seq = msg.get("seq") or msg.get("id")
                    if isinstance(seq, int):
                        runtime_state["cursor_position"] = seq
                except Exception as e:
                    # Append failure must NOT advance cursor — re-raise to
                    # tear down the connection and reconnect from prior cursor.
                    sys.stderr.write(f"yaklog-sub: append failed: {e}; reconnecting\n")
                    sys.stderr.flush()
                    raise

            try:
                parse_sse(resp, on_event, lambda: stop["flag"])
            except Exception as e:
                sys.stderr.write(f"yaklog-sub: stream error: {e}\n")
                sys.stderr.flush()
            finally:
                runtime_state["sse_connected"] = False
                try:
                    resp.close()
                except Exception:
                    pass

            if not stop["flag"]:
                _sleep_interruptible(DEFAULT_RECONNECT_MIN_S, stop)
    finally:
        log.close()
        # Wait briefly for presence publisher's final-beat
        if presence_thread is not None:
            presence_thread.join(timeout=5.0)
        try:
            os.close(lock_fd)
        except Exception:
            pass

    return 0


def _sleep_interruptible(seconds: float, stop: dict) -> None:
    end = time.monotonic() + seconds
    while not stop["flag"] and time.monotonic() < end:
        time.sleep(min(0.2, end - time.monotonic()))


def main(argv=None) -> int:
    p = argparse.ArgumentParser(description="yaklog SSE broker daemon")
    p.add_argument("--agent-id", required=True, help="agent identity (sender / exclude_sender)")
    p.add_argument("--aliases", default="", help="comma-separated aliases for mention filter")
    p.add_argument("--url", required=True, help="yaklog API base, e.g. http://host:3100/api/v1")
    p.add_argument("--token-file", required=True, help="path to file containing the API token")
    # ADR-0016 Phase-1 (yaklog #4280) — daemon presence/liveness publisher
    p.add_argument("--presence-url", default=None,
                   help="yaklog presence-base; defaults to --url. Ignored when --presence-disabled.")
    p.add_argument("--presence-disabled", action="store_true",
                   help="opt out of presence publishing (use only if server side does not support /presence/event yet)")
    p.add_argument("--heartbeat-s", type=float, default=DEFAULT_HEARTBEAT_S,
                   help=f"presence heartbeat interval in seconds (default {DEFAULT_HEARTBEAT_S})")
    p.add_argument("--stall-threshold-s", type=float, default=DEFAULT_STALL_THRESHOLD_S,
                   help=f"no-hook-fire threshold flipping session_state to unknown (default {DEFAULT_STALL_THRESHOLD_S})")
    # ADR-0016 Phase-1.5 — Q5(a) #agents back-compat
    p.add_argument("--no-agents-backcompat", action="store_true",
                   help="disable ADR-0016 P1.7 #agents back-compat post on startup/shutdown (default: enabled)")
    p.add_argument("--host", default=None,
                   help="hostname to advertise in #agents back-compat events (default: os.uname().nodename)")
    p.add_argument("--version", action="version", version=f"yaklog-sub {VERSION}")
    args = p.parse_args(argv)
    return run(args)


if __name__ == "__main__":
    sys.exit(main())
