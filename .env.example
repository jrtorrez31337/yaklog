NODE_ENV=production
HOST=0.0.0.0
PORT=3100
YAKLOG_BIND_IP=0.0.0.0
YAKLOG_DB_PATH=/data/yaklog.db
YAKLOG_API_KEYS=replace-with-a-long-random-token
CORS_ORIGIN=*
MAX_BODY_BYTES=1000000
# Path on the server where the canonical agent spec lives. Served as
# text/markdown via GET /api/v1/spec with a sha256 ETag. Mount a host file
# into /data/spec.md (or wherever you point this at) so agents can fetch
# the current canonical spec without per-host mirror drift.
YAKLOG_SPEC_PATH=/data/spec.md
# Host-side path to the canonical agent spec file. docker-compose
# bind-mounts this read-only into the container at /data/spec.md
# (resolved by YAKLOG_SPEC_PATH above). Default `./spec.md` is the
# placeholder shipped in the repo — replace with your own
# operator-canonical spec or override here with an absolute path.
YAKLOG_SPEC_FILE=./spec.md
